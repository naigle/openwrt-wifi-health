#!/bin/sh
echo "Content-Type: application/json"
echo "Cache-Control: no-cache"
echo ""

# === SYSTEM ===
uptime_s=$(awk '{print int($1)}' /proc/uptime)
days=$((uptime_s/86400))
hrs=$(( (uptime_s%86400)/3600 ))
mins=$(( (uptime_s%3600)/60 ))
load1=$(awk '{print $1}' /proc/loadavg)
load5=$(awk '{print $2}' /proc/loadavg)
load15=$(awk '{print $3}' /proc/loadavg)
mem_total=$(awk '/MemTotal/{print $2}'     /proc/meminfo)
mem_avail=$(awk '/MemAvailable/{print $2}' /proc/meminfo)
mem_used=$((mem_total - mem_avail))
mem_pct=$((mem_used * 100 / mem_total))

# === WAN — auto-detect from default route ===
wan_if=$(ip route 2>/dev/null | awk '/^default/{print $5; exit}')
[ -z "$wan_if" ] && wan_if=$(ip route 2>/dev/null | awk '/^default/{print $NF; exit}')
wan_ip=$(ip addr show "$wan_if" 2>/dev/null | awk '/inet /{gsub(/\/[0-9]+$/,"",$2); print $2; exit}')
[ -n "$wan_ip" ] && wan_state="up" || wan_state="down"
[ -z "$wan_ip" ] && wan_ip=""
ping_ms=$(ping -c 2 -W 1 8.8.8.8 2>/dev/null | awk -F'/' '/avg/{printf "%.1f",$5}')
[ -z "$ping_ms" ] && ping_ms="null"

# === AP INTERFACES — auto-detect all interfaces in AP mode ===
AP_IFACES=$(iw dev 2>/dev/null | awk '/Interface/{iface=$2} /type AP/{print iface}')

# === RADIOS ===
radio_json=""
for iface in $AP_IFACES; do
    [ -d "/sys/class/net/$iface" ] || continue
    info=$(iw dev "$iface" info 2>/dev/null)
    channel=$(echo "$info" | awk '/channel/{print $2}')
    freq=$(echo    "$info" | awk '/channel/{gsub(/.*\(/,""); gsub(/ MHz.*/,""); print}')
    width=$(echo   "$info" | awk '/width:/{print $6}')
    txpwr=$(echo   "$info" | awk '/txpower/{print $2}')
    if   [ "${freq:-0}" -lt 3000 ]; then band="2.4GHz"
    elif [ "${freq:-0}" -lt 5925 ]; then band="5GHz"
    else band="6GHz"; fi
    survey=$(iw dev "$iface" survey dump 2>/dev/null)
    noise=$(echo    "$survey" | awk '/in use/{f=1} f&&/noise:/{print $2; exit}')
    util=$(echo     "$survey" | awk -v freq="$freq" '/frequency:/{f=0} $0~(freq" MHz.*in use"){f=1} f&&/active time:/{a=$(NF-1)} f&&/busy time:/{b=$(NF-1)}     END{if(a>0)printf "%.1f",b/a*100; else print "0"}')
    tx_util=$(echo  "$survey" | awk -v freq="$freq" '/frequency:/{f=0} $0~(freq" MHz.*in use"){f=1} f&&/active time:/{a=$(NF-1)} f&&/transmit time:/{t=$(NF-1)} END{if(a>0)printf "%.1f",t/a*100; else print "0"}')
    rx_util=$(echo  "$survey" | awk -v freq="$freq" '/frequency:/{f=0} $0~(freq" MHz.*in use"){f=1} f&&/active time:/{a=$(NF-1)} f&&/receive time:/{r=$(NF-1)}  END{if(a>0)printf "%.1f",r/a*100; else print "0"}')
    sta_count=$(iw dev "$iface" station dump 2>/dev/null | grep -c '^Station')
    [ -n "$radio_json" ] && radio_json="$radio_json,"
    radio_json="${radio_json}{\"iface\":\"${iface}\",\"band\":\"${band}\",\"channel\":${channel:-0},\"width\":${width:-0},\"txpower\":${txpwr:-0},\"noise\":${noise:-0},\"utilization\":${util:-0},\"tx_util\":${tx_util:-0},\"rx_util\":${rx_util:-0},\"stations\":${sta_count:-0}}"
done

# === STATIONS ===
tmpfile=$(mktemp /tmp/wh_XXXXXX)
for iface in $AP_IFACES; do
    [ -d "/sys/class/net/$iface" ] || continue
    freq=$(iw dev "$iface" info 2>/dev/null | awk '/channel/{gsub(/.*\(/,""); gsub(/ MHz.*/,""); print}')
    if   [ "${freq:-0}" -lt 3000 ]; then band="2.4GHz"
    elif [ "${freq:-0}" -lt 5925 ]; then band="5GHz"
    else band="6GHz"; fi
    iw dev "$iface" station dump 2>/dev/null | awk -v iface="$iface" -v band="$band" '
    function emit() {
        if (mac=="") return
        pct = (tx_pkt>0) ? tx_fail/tx_pkt*100 : 0
        printf "{\"mac\":\"%s\",\"iface\":\"%s\",\"band\":\"%s\",\"signal\":%d,\"tx_rate\":%.1f,\"rx_rate\":%.1f,\"tx_failed_pct\":%.1f,\"tx_retries\":%d,\"tx_packets\":%d,\"inactive_ms\":%d}\n",
            mac,iface,band,signal+0,tx_rate+0,rx_rate+0,pct,retries+0,tx_pkt+0,inactive+0
    }
    /^Station/ { emit(); mac=$2; signal=0; tx_rate=0; rx_rate=0; tx_fail=0; tx_pkt=0; retries=0; inactive=0 }
    /inactive time:/   { inactive=$3 }
    /signal: /&&!/avg/ { signal=$2 }
    /tx bitrate:/      { tx_rate=$3 }
    /rx bitrate:/      { rx_rate=$3 }
    /tx packets:/      { tx_pkt=$3 }
    /tx failed:/       { tx_fail=$3 }
    /tx retries:/      { retries=$3 }
    END { emit() }
    ' >> "$tmpfile"
done

# Enrich with hostnames from DHCP leases (busybox awk compatible)
sta_json=$(awk '
NR==FNR { lease[$2]=($4=="*"?"":$4); next }
{
    line=$0
    mac=line; gsub(/.*"mac":"/, "", mac); gsub(/".*/, "", mac)
    name=(mac in lease) ? lease[mac] : ""
    sub(/\}$/, ",\"hostname\":\""name"\"}", line)
    if (FNR>1) printf ","
    printf "%s", line
}
' /tmp/dhcp.leases "$tmpfile" 2>/dev/null)

[ -z "$sta_json" ] && sta_json=$(awk 'FNR>1{printf ","} {sub(/\}$/,",\"hostname\":\"\"}"); printf "%s",$0}' "$tmpfile")
rm -f "$tmpfile"

printf '{"timestamp":"%s","uptime":"%dd %dh %dm","uptime_s":%d,"load1":%s,"load5":%s,"load15":%s,"mem_total_mb":%d,"mem_used_mb":%d,"mem_pct":%d,"wan_state":"%s","wan_ip":"%s","ping_ms":%s,"radios":[%s],"stations":[%s]}' \
    "$(date '+%Y-%m-%d %H:%M:%S')" \
    "$days" "$hrs" "$mins" "$uptime_s" \
    "$load1" "$load5" "$load15" \
    "$((mem_total/1024))" "$((mem_used/1024))" "$mem_pct" \
    "$wan_state" "$wan_ip" "$ping_ms" \
    "$radio_json" \
    "$sta_json"
